[Unit]
Description=Weekly trigger for AgenticApps architecture audit reminder
Documentation=https://github.com/agenticapps-eu/claude-workflow

[Timer]
# Mondays at 09:00 local — matches the launchd schedule.
OnCalendar=Mon *-*-* 09:00:00
# Run on next boot if the trigger window was missed (laptop closed, etc.).
Persistent=true
Unit=agenticapps-architecture-cron.service

[Install]
WantedBy=timers.target
