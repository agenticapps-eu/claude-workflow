<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>eu.agenticapps.architecture-cron</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>{SCAFFOLDER_BIN}/agenticapps-architecture-cron.sh</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>{HOME}/.agenticapps/logs/architecture-cron-stdout.log</string>

  <key>StandardErrorPath</key>
  <string>{HOME}/.agenticapps/logs/architecture-cron-stderr.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
