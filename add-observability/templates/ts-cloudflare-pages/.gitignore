# Mirror of openrouter-monitor/.gitignore (Phase 24); extended to
# ts-cloudflare-pages in Phase 26 (D-08). Template-only — operators may
# extend for project-specific paths.

# Secrets — NEVER commit. README §5 documents this exclusion as a security
# guarantee; this file makes the guarantee true the instant a consumer copies
# the template into their own repo.
.dev.vars
.env
.env.local
.env.*.local

# Generated by `npm install` / `wrangler dev`
node_modules/
.wrangler/

# Build artifacts (none today, but `wrangler pages deploy` may emit to .wrangler/dist)
dist/
